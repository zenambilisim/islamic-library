# Supabase – sadece sunucuda kullanılır (tarayıcıya gönderilmez)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
# Kitap/kapak yükleme ve silme için RLS bypass (gizli tutun, tarayıcıya koymayın)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare R2 (S3 uyumlu) – tanımlıysa dosyalar Supabase Storage yerine R2’ye gider; DB yine Supabase.
# S3 API endpoint (bucket adı OLMADAN): https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=islamic-library
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# İsteğe bağlı: doğrudan R2 genel URL — sadece r2.dev veya kendi domaininiz (S3 API adresi DEĞİL: *.r2.cloudflarestorage.com kullanmayın).
# Boş bırakılırsa dosyalar /api/storage/r2/… üzerinden sunulur.
# NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Eski projeler için (tercih edilmez): NEXT_PUBLIC_* kullanılırsa fallback olarak okunur
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# EmailJS (Contact Form) – client'ta kullanılıyor
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
