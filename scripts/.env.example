# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Upload Configuration
BOOKS_FOLDER_PATH=../Books_en
LANGUAGE=en
DRY_RUN=true
BATCH_SIZE=1

# ============================================================================
# NOTES:
# ============================================================================
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env to git (it contains sensitive keys)
# 3. Get Service Role Key from: Supabase Dashboard → Settings → API
# 4. Set DRY_RUN=false when ready for real uploads
# 5. Supported LANGUAGE values: en, tr, ru, az
